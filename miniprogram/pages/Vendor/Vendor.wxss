/* pages/Vendor/Vendor.wxss */
.container {
  padding: 12px 16px;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 店铺卡片 */
.shop-card {
  background: white;
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 16px;
}

.shop-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 0.5px solid #f0f0f0;
}

.shop-icon {
  font-size: 48px;
}

.shop-info {
  flex: 1;
}

.shop-name {
  font-size: 18px;
  font-weight: 700;
  display: block;
  margin-bottom: 4px;
}

.shop-status {
  font-size: 12px;
  background: #e8f5e9;
  color: #4caf50;
  padding: 4px 10px;
  border-radius: 20px;
  display: inline-block;
}

.shop-status.closed {
  background: #ffebee;
  color: #f44336;
}

.shop-detail {
  margin-bottom: 16px;
}

.detail-row {
  display: flex;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}

.detail-row text:first-child {
  width: 100px;
  color: rgb(71, 71, 71);
}

.detail-row text:last-child {
  flex: 1;
}

.edit-btn {
  background: #f5f5f5;
  border-radius: 30px;
  text-align: center;
  padding: 10px;
  font-size: 13px;
  color: #ff7a1c;
}

/* 商品区域 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  font-size: 16px;
  font-weight: 600;
}

.add-btn {
  background: #ff7a1c;
  color: white;
  padding: 6px 14px;
  border-radius: 30px;
  font-size: 12px;
  font-weight: normal;
}

.product-list {
  background: white;
  border-radius: 20px;
  overflow: hidden;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 0.5px solid #f0f0f0;
}

.product-item:last-child {
  border-bottom: none;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 15px;
  font-weight: 600;
  display: block;
}

.product-price {
  font-size: 14px;
  color: #ff7a1c;
  font-weight: 600;
  margin-right: 12px;
}

.product-desc {
  font-size: 12px;
  color: #999;
  display: block;
  margin-top: 4px;
}

.product-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

.product-actions .edit,
.product-actions .delete {
  font-size: 20px;
}

.status-switch {
  transform: scale(0.8);
}

.empty-state,
.no-shop {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  background: white;
  border-radius: 20px;
}

.empty-state text:first-child,
.no-shop text:first-child {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-state text:last-child,
.no-shop text:last-child {
  font-size: 14px;
  color: #999;
}

.apply-btn {
  background: #ff7a1c;
  border-radius: 40px;
  padding: 12px 30px;
  margin-top: 20px;
  font-size: 14px;
  color: white;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  width: 85%;
  max-height: 80%;
  background: white;
  border-radius: 24px;
  overflow: hidden;
  display: flex;
  flex-direction: column; 
}

.modal-title {
  text-align: center;
  font-size: 18px;
  font-weight: 600;
  padding: 20px;
  border-bottom: 0.5px solid #f0f0f0;
}

.modal-content {
  padding: 20px;
  max-height: 500px;
  overflow-y: auto;
}

.modal-item {
  margin-bottom: 16px;
  width: 100%;
  overflow: hidden;
}

.required {
  color: #ff4d4f !important;
  font-size: 14px;
  display: inline;
}

.modal-item .modal-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
  display: block;
}

.modal-input,
.modal-textarea {
  width: 100%;
  min-height: 48px;
  box-sizing: border-box;
  background: #f5f5f5;
  border-radius: 12px;
  padding: 12px 14px;
  font-size: 14px;
}

.modal-textarea {
  min-height: 80px;
}

.upload-img {
  width: 100%;
  height: 120px;
  background: #f5f5f5;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: #999;
  overflow: hidden;
}

.upload-img image {
  width: 100%;
  height: 100%;
}

.modal-buttons {
  display: flex;
  border-top: 0.5px solid #f0f0f0;
}

.modal-cancel,
.modal-confirm {
  flex: 1;
  text-align: center;
  padding: 16px;
  font-size: 16px;
}

.modal-cancel {
  color: #999;
  border-right: 0.5px solid #f0f0f0;
}

.modal-confirm {
  color: #ff7a1c;
  font-weight: 600;
}