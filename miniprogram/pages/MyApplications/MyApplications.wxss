/* pages/MyApplications/MyApplications.wxss */
.container {
  padding: 16px;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.application-card {
  background: white;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 12px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 10px;
  border-bottom: 0.5px solid #f0f0f0;
}

.shop-name {
  font-size: 16px;
  font-weight: 600;
}

.status {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 20px;
}

.status.pending {
  background: #fff3e0;
  color: #ff9800;
}

.status.approved {
  background: #e8f5e9;
  color: #4caf50;
}

.status.rejected {
  background: #ffebee;
  color: #f44336;
}

.card-info {
  margin-bottom: 12px;
}

.info-row {
  display: flex;
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}

.info-row text:first-child {
  width: 100px;
  color: #999;
}

.card-footer {
  padding-top: 10px;
  border-top: 0.5px solid #f0f0f0;
}

.action-btn {
  background: #ff7a1c;
  border-radius: 30px;
  text-align: center;
  padding: 10px;
  font-size: 14px;
  color: white;
}

.action-btn.retry {
  background: #e0e0e0;
  color: #ff7a1c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 14px;
  color: #999;
  margin-bottom: 24px;
}

.apply-btn {
  background: #ff7a1c;
  border-radius: 40px;
  padding: 12px 30px;
  font-size: 14px;
  font-weight: 600;
  color: white;
}