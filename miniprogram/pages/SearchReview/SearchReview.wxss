/* pages/SearchReview/SearchReview.wxss */
.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 20px;
}

/* 搜索头部 */
.search-header {
  background: white;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  position: fixed; 
  top: 0;
  left: 0;
  width: 100%;
  height: 64px;
  box-sizing: border-box;
  z-index: 100;
}

.search-bar {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30px;
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.search-input {
  flex: 1;
  font-size: 15px;
  background: transparent;
}

.clear-btn {
  font-size: 18px;
  color: #999;
  padding: 0 4px;
}

.cancel-btn {
  font-size: 15px;
  color: #666;
}

/* 区域通用 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.history-section {
  background: white;
  margin: 64px 6px 6px 6px;
  padding: 16px;
  border-radius: 20px;
}

.hot-section {
  background: white;
  margin:12px 6px;
  padding: 16px;
  border-radius: 20px;
}

.clear-history {
  font-size: 13px;
  color: #999;
}

/* 标签样式 */
.history-tags, .hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.history-tag {
  background: #f5f5f5;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
  color: #666;
}

.hot-tag {
  background: #fff1e6;
  padding: 4px 12px;
  border-radius: 30px;
  font-size: 13px;
  color: #ff7a1c;
}

/* 筛选栏 */
.filter-bar {
  background: rgb(252, 252, 252);
  padding: 10px 16px;
  display: flex;
  gap: 24px;
  border-bottom: 0.5px solid #f0f0f0;
  position: fixed;
  top: 64px;
  left: 0;
  width: 100%;
  height: 48px;
  box-sizing: border-box;
  z-index: 99;
}

.filter-item {
  font-size: 14px;
  color: #666;
  padding-bottom: 8px;
}

.filter-item.active {
  color: #ff7a1c;
  border-bottom: 2px solid #ff7a1c;
}

/* 结果统计 */
.result-stats {
  margin: 108px 16px 12px 16px;
  font-size: 12px;
  color: #999;
}

/* 搜索结果列表 */
.result-list {
  padding: 0 16px;
}

.review-item {
  background: white;
  border-radius: 20px;
  padding: 0px 16px 12px 16px;
  margin-bottom: 12px;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.reviewer-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.reviewer-name {
  font-size: 14px;
  font-weight: 500;
}

.rating {
  display: flex;
  gap: 2px;
}

/* 合并标签区域 */
.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 8px 0;
}

.shop-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 8px 0;
}

.shop-tag {
  background: #fff1e6;
  color: #ff7a1c;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 11px;
}

.topic-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 8px 0;
}

.topic-tag {
  background: #e8f5e9;
  color: #4caf50;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 11px;
}

.review-content {
  font-size: 14px;
  color: #333;
  line-height: 1.4;
  margin: 10px 0;
}

.review-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8px;
}

.like-info {
  font-size: 12px;
  color: #999;
}

.review-time {
  font-size: 11px;
  color: #999;
}

/* 高亮关键词 */
.highlight {
  background: #fff3e0;
  color: #ff7a1c;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  font-weight: 500;
  color: #666;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 13px;
  color: #999;
}

.loading-more {
  text-align: center;
  padding: 20px;
  font-size: 12px;
  color: #999;
}