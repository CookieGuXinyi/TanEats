/* pages/MyFavorites/MyFavorites.wxss */
.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding: 16px;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #ff7a1c, #ff9f4a);
  border-radius: 24px;
  padding: 20px;
  text-align: center;
  margin-bottom: 16px;
}

.stats-value {
  font-size: 32px;
  font-weight: 700;
  color: white;
  display: block;
}

.stats-label {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4px;
}

/* 收藏列表 */
.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.favorite-item {
  background: white;
  border-radius: 20px;
  padding: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s;
}

.item-left {
  display: flex;
  gap: 12px;
  flex: 1;
}

.stall-icon {
  font-size: 40px;
}

.stall-info {
  flex: 1;
}

.stall-name {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 6px;
}

.stall-meta {
  display: flex;
  gap: 12px;
  margin-bottom: 6px;
}

.category {
  font-size: 12px;
  color: #ff7a1c;
  background: #fff1e6;
  padding: 2px 8px;
  border-radius: 20px;
}

.rating {
  font-size: 12px;
  color: #ffb800;
}

.stall-address {
  font-size: 11px;
  color: #999;
}

.item-right {
  margin-left: 12px;
}

.unfavorite-btn {
  background: #f5f5f5;
  padding: 8px 14px;
  border-radius: 30px;
  font-size: 12px;
  color: #ff4d4f;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
  background: white;
  border-radius: 24px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  font-weight: 500;
  color: #666;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 13px;
  color: #999;
  margin-bottom: 24px;
}

.go-search-btn {
  background: #ff7a1c;
  color: white;
  padding: 10px 30px;
  border-radius: 40px;
  font-size: 14px;
}

.loading-state {
  text-align: center;
  padding: 40px;
  color: #999;
}