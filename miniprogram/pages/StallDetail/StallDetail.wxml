<!--pages/StallDetail/StallDetail.wxml-->
<view class="container" wx:if="{{stall}}">
  
  <!-- 店铺头部信息 -->
  <view class="stall-header">
    <view class="stall-icon">🏪</view>
    <view class="stall-info">
      <text class="stall-name">{{stall.shopName}}</text>
      <view class="stall-meta">
        <text class="category">{{stall.category}}</text>
        <text class="status {{isOpen ? 'open' : 'closed'}}">{{isOpen ? '营业中' : '已打烊'}}</text>
      </view>
    </view>
  </view>

  <!-- 营业信息卡片 -->
  <view class="info-card">
    <view class="info-row">
      <text>⏰ 营业时间</text>
      <text>{{stall.businessHours}}</text>
    </view>
    <view class="info-row">
      <text>📍 店铺位置</text>
      <text>{{stall.location}}</text>
    </view>
    <view class="info-row" wx:if="{{stall.description}}">
      <text>📝 店铺简介</text>
      <text>{{stall.description}}</text>
    </view>
    <view class="info-row" wx:if="{{stall.qrCodeUrl}}">
      <text>💬 微信群</text>
      <text class="qr-link" bindtap="previewQRCode">点击查看群二维码</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="section-title">
    <text>🍜 菜单</text>
  </view>

  <view class="product-list">
    <block wx:for="{{products}}" wx:key="_id">
      <view class="product-item" wx:if="{{item.isAvailable}}">
        <view class="product-image" wx:if="{{item.imageUrl}}">
          <image src="{{item.imageUrl}}" mode="aspectFill"></image>
        </view>
        <view class="product-image placeholder" wx:else>
          <text>🍽️</text>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.description}}</text>
        </view>
        <view class="product-right">
          <text class="product-price">¥{{item.price}}</text>
          <view class="add-btn" bindtap="addToCart" data-product="{{item}}">+</view>
        </view>
      </view>
    </block>
  </view>

  <!-- 暂无商品 -->
  <view class="empty-state" wx:if="{{products.length === 0}}">
    <text>📦</text>
    <text>暂无菜单，敬请期待</text>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>

</view>

<!-- 加载中 -->
<view class="loading" wx:else>
  <text>加载中... 尚未找到此店铺</text>
</view>