/* pages/StallDetail/StallDetail.wxss */
.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 20px;
}

/* 店铺头部 */
.stall-header {
  background: linear-gradient(135deg, #ff7a1c, #ff9f4a);
  padding: 32px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.stall-icon {
  font-size: 56px;
  background: rgba(255,255,255,0.2);
  width: 80px;
  height: 80px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stall-info {
  flex: 1;
}

.stall-name {
  font-size: 22px;
  font-weight: 700;
  color: white;
  display: block;
  margin-bottom: 8px;
}

.stall-meta {
  display: flex;
  gap: 10px;
}

.category {
  background: rgba(255,255,255,0.2);
  color: white;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
}

.status {
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
}

.status.open {
  background: #4caf50;
  color: white;
}

.status.closed {
  background: rgba(255,255,255,0.3);
  color: white;
}

/* 信息卡片 */
.info-card {
  background: white;
  margin: 16px;
  padding: 16px;
  border-radius: 20px;
}

.info-row {
  display: flex;
  padding: 10px 0;
  border-bottom: 0.5px solid #f0f0f0;
  font-size: 14px;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row text:first-child {
  width: 100px;
  color: #999;
}

.info-row text:last-child {
  flex: 1;
  color: #333;
}

.qr-link {
  color: #ff7a1c;
  text-decoration: underline;
}

/* 菜单区域 */
.section-title {
  font-size: 18px;
  font-weight: 600;
  margin: 0 16px 12px;
  padding-left: 10px;
  border-left: 3px solid #ff7a1c;
}

.product-list {
  background: white;
  margin: 0 16px;
  border-radius: 20px;
  overflow: hidden;
}

.product-image {
  width: 60px;
  height: 60px;
  border-radius: 12px;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 12px;
}

.product-image image {
  width: 100%;
  height: 100%;
}

.product-image.placeholder {
  font-size: 28px;
  color: #ccc;
}

.product-item {
  display: flex;
  /* justify-content: space-between; */
  align-items: center;
  padding: 16px;
  border-bottom: 0.5px solid #f0f0f0;
}

.product-item:last-child {
  border-bottom: none;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 16px;
  font-weight: 600;
  display: block;
  margin-bottom: 4px;
}

.product-desc {
  font-size: 12px;
  color: #999;
}

.product-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.product-price {
  font-size: 16px;
  font-weight: 600;
  color: #ff7a1c;
}

.add-btn {
  width: 32px;
  height: 32px;
  background: #ff7a1c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 20px;
  font-weight: bold;
}

.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #999;
}

.empty-state text:first-child {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}

.loading {
  text-align: center;
  padding: 60px;
  color: #999;
}

.bottom-placeholder {
  height: 20px;
}