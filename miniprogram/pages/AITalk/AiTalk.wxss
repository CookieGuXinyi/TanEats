/* pages/AITalk/AiTalk.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8f8f8;
}

.chat-header {
  background: white;
  padding: 20px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  border-bottom: 0.5px solid #f0f0f0;
}

.ai-avatar {
  background: linear-gradient(135deg, #ff7a1c, #ff9f4a);
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  color: white;
}

.ai-name {
  font-size: 16px;
  font-weight: 600;
}

.ai-desc {
  font-size: 12px;
  color: #999;
}

.chat-area {
  flex: 1;
  padding: 16px;
  padding-bottom: 20px;
}

.message-item {
  margin-bottom: 16px;
  display: flex;
  flex-direction: column;
}

.message-bubble {
  max-width: 80%;
  padding: 12px 16px;
  border-radius: 20px;
  font-size: 14px;
  word-wrap: break-word;
}

.ai-bubble {
  background: white;
  color: #333;
  border-top-left-radius: 4px;
  align-self: flex-start;
}

.user-bubble {
  background: #ff7a1c;
  color: white;
  border-top-right-radius: 4px;
  align-self: flex-end;
}

.message-time {
  font-size: 10px;
  color: #aaa;
  margin-top: 4px;
  margin-left: 12px;
}

.quick-questions {
  background: white;
  padding: 12px 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  border-top: 0.5px solid #f0f0f0;
  border-bottom: 0.5px solid #f0f0f0;
}

.quick-item {
  background: #f5f5f5;
  padding: 8px 14px;
  border-radius: 30px;
  font-size: 13px;
  color: #ff7a1c;
}

.input-area {
  background: white;
  padding: 12px 16px;
  display: flex;
  gap: 12px;
  align-items: center;
  border-top: 0.5px solid #f0f0f0;
}

.input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30px;
  padding: 10px 16px;
  font-size: 14px;
}

.send-btn {
  width: 42px;
  height: 42px;
  background: #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  transition: all 0.2s;
}

.send-btn.active {
  background: #ff7a1c;
}