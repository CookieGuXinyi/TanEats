/* pages/Map/Map.wxss */
.container {
  padding: 12px 16px;
}

.map-hero {
  background: linear-gradient(135deg, #ff7a1c, #ff9f4a);
  border-radius: 24px;
  padding: 20px;
  color: white;
  margin-bottom: 12px;
}

.hero-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 18px;
}

.hero-title {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 6px;
}

.hero-desc {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.82);
}

.hero-icon {
  width: 58px;
  height: 58px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
  display: flex;
  justify-content: center;
  font-size: 34px;
  flex-shrink: 0;
}

.hero-stats {
  display: flex;
  justify-content: space-between;
  gap: 10px;
}

.hero-stat {
  flex: 1;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 16px;
  padding: 10px 8px;
  text-align: center;
}

.hero-value {
  display: block;
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 3px;
}

.hero-label {
  display: block;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.82);
}

.search-bar {
  background: #ffffff;
  border-radius: 30px;
  padding: 10px 14px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.clear-btn {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #f2f2f2;
  color: #999;
  text-align: center;
  line-height: 22px;
  font-size: 16px;
}

.filter-scroll {
  white-space: nowrap;
  margin-bottom: 12px;
}

.filter-list {
  display: flex;
  gap: 10px;
  padding-right: 16px;
}

.filter-item {
  flex-shrink: 0;
  background: #ffffff;
  border-radius: 30px;
  padding: 9px 14px;
  color: #666;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 6px;
  border: 0.5px solid #f0f0f0;
}

.filter-item.active {
  background: #fff1e6;
  border-color: #ffd6ba;
  color: #ff7a1c;
  font-weight: 600;
}

.map-card {
  background: #ffffff;
  border-radius: 20px;
  padding: 12px;
  margin-bottom: 12px;
}

.campus-map {
  width: 100%;
  height: 260px;
  border-radius: 16px;
  overflow: hidden;
}

.map-actions {
  display: flex;
  gap: 10px;
  margin-top: 12px;
}

.map-action {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30px;
  padding: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  color: #666;
  font-size: 14px;
  font-weight: 500;
}

.map-action.primary {
  background: #ff7a1c;
  color: white;
}

.stall-card,
.list-card {
  background: #ffffff;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 12px;
}

.stall-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 14px;
}

.stall-name {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  margin-bottom: 4px;
}

.stall-meta {
  font-size: 12px;
  color: #999;
}

.status-pill {
  border-radius: 30px;
  padding: 5px 10px;
  font-size: 12px;
  flex-shrink: 0;
}

.status-pill.open {
  background: #e8f5e9;
  color: #4caf50;
}

.status-pill.closed {
  background: #eeeeee;
  color: #999999;
}

.stall-data {
  display: flex;
  border-radius: 16px;
  background: #fafafa;
  padding: 12px 0;
  margin-bottom: 12px;
}

.data-item {
  flex: 1;
  text-align: center;
  border-right: 0.5px solid #eeeeee;
}

.data-item:last-child {
  border-right: none;
}

.data-value {
  display: block;
  color: #ff7a1c;
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 4px;
}

.data-label {
  display: block;
  color: #999;
  font-size: 11px;
}

.coupon-row {
  background: #fff7e8;
  border-radius: 14px;
  padding: 10px 12px;
  margin-bottom: 12px;
  color: #ff7a1c;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 14px;
}

.tag {
  background: #f5f5f5;
  color: #666;
  border-radius: 30px;
  padding: 6px 10px;
  font-size: 12px;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.action-btn {
  background: #f8f8f8;
  border-radius: 16px;
  padding: 12px 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: #666;
}

.card-title {
  font-weight: 600;
  font-size: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.more-text {
  font-size: 12px;
  color: #ff7a1c;
}

.stall-list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 13px 0;
  border-bottom: 0.5px solid #f0f0f0;
}

.stall-list-item:last-child {
  border-bottom: none;
}

.stall-list-item.selected {
  background: #fffaf5;
  margin: 0 -8px;
  padding-left: 8px;
  padding-right: 8px;
  border-radius: 14px;
}

.list-left {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.list-icon {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #fff1e6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.list-name {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 3px;
}

.list-desc {
  font-size: 12px;
  color: #999;
  max-width: 220px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.list-right {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #ff7a1c;
  font-size: 12px;
  flex-shrink: 0;
}

.empty-state {
  padding: 28px 0 16px;
  text-align: center;
  font-size: 13px;
  color: #aaa;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
