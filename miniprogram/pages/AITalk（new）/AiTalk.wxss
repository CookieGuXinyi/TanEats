/* pages/AITalk/AiTalk.wxss */
page {
  height: 100%;
  background: #f7f4ef;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f7f4ef;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 22rpx;
  background: #fffaf3;
  border-bottom: 1rpx solid #eadfce;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #25211d;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a7662;
}

.clear-btn {
  width: 116rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  margin: 0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #7a6756;
  font-size: 24rpx;
  border: 1rpx solid #eadfce;
}

.clear-btn::after,
.send-btn::after {
  border: none;
}

.chat-list {
  flex: 1;
  box-sizing: border-box;
  height: 0;
  padding: 28rpx 28rpx 16rpx;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
}

.message-user {
  justify-content: flex-end;
}

.message-assistant {
  justify-content: flex-start;
}

.bubble {
  max-width: 82%;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  border-radius: 8rpx;
  font-size: 29rpx;
  line-height: 1.65;
  word-break: break-word;
  white-space: pre-wrap;
}

.message-user .bubble {
  background: #ff7a1c;
  color: #ffffff;
}

.message-assistant .bubble {
  background: #ffffff;
  color: #2f2924;
  border: 1rpx solid #eadfce;
}

.content {
  white-space: pre-wrap;
}

.source-shops {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f0e4d5;
}

.source-title {
  margin-bottom: 12rpx;
  font-size: 23rpx;
  color: #8a7662;
}

.shop-card {
  padding: 16rpx;
  margin-top: 12rpx;
  background: #fff7ed;
  border: 1rpx solid #f0d9bd;
  border-radius: 8rpx;
}

.shop-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.shop-name {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  font-weight: 700;
  color: #2d241c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-status {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 21rpx;
}

.shop-status.open {
  color: #16794d;
  background: #e5f5ed;
}

.shop-status.closed {
  color: #8a7662;
  background: #efe7dd;
}

.shop-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8a7662;
}

.fallback-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9b6a25;
}

.quick-section {
  display: flex;
  gap: 14rpx;
  padding: 8rpx 28rpx 22rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.quick-chip {
  flex-shrink: 0;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #6f5b48;
  font-size: 24rpx;
  border: 1rpx solid #eadfce;
}

.input-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #fffaf3;
  border-top: 1rpx solid #eadfce;
}

.input {
  flex: 1;
  height: 76rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #2f2924;
  font-size: 27rpx;
  border: 1rpx solid #eadfce;
}

.send-btn {
  width: 128rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  margin: 0;
  border-radius: 8rpx;
  background: #ff7a1c;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
}

.send-btn[disabled] {
  background: #d9c8b8;
  color: #ffffff;
}
