/* pages/Register_Vendor/Register_Vendor.wxss */
.container {
  padding: 16px;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.form-card {
  background: white;
  border-radius: 24px;
  padding: 24px 20px;
}

.form-title {
  font-size: 22px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 8px;
}

.form-desc {
  text-align: center;
  font-size: 13px;
  color: #999;
  margin-bottom: 28px;
}

.form-item {
  margin-bottom: 24px;
}

.form-label {
  font-size: 15px;
  font-weight: 500;
  display: block;
  margin-bottom: 10px;
}

.required {
  color: #ff4d4f;
}

/* 统一所有输入类元素的宽度 */
.form-input,
.form-textarea,
.picker-view,
.upload-area {
  width: 100%;
  box-sizing: border-box;
}

.form-input {
  background: #f5f5f5;
  border-radius: 12px;
  min-height: 48px;
  padding: 12px 16px;
  font-size: 14px;
}

.form-textarea {
  background: #f5f5f5;
  border-radius: 12px;
  padding: 12px 16px;
  font-size: 14px;
  min-height: 100px;
}

.char-count {
  text-align: right;
  font-size: 11px;
  color: #bbb;
  margin-top: 6px;
}

.picker-view {
  background: #f5f5f5;
  border-radius: 12px;
  height: 48px;
  padding: 12px 16px;
  display: flex;
  font-size: 14px;
  justify-content: space-between;
  align-items: center;
  color: #333;
}

.upload-area {
  background: #f5f5f5;
  border-radius: 12px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: #999;
  font-size: 13px;
}

.upload-icon {
  font-size: 28px;
}

.upload-hint {
  font-size: 11px;
  color: #bbb;
  margin-top: 8px;
}

.preview-image {
  width: 100%;
  max-height: 200px;
  border-radius: 12px;
  margin-top: 12px;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 12px;
}

.image-item {
  position: relative;
  width: 100px;
  height: 100px;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 8px;
}

.delete-btn {
  position: absolute;
  top: -8px;
  right: -8px;
  width: 24px;
  height: 24px;
  background: #ff4d4f;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.submit-btn {
  background: #e0e0e0;
  border-radius: 40px;
  text-align: center;
  padding: 14px;
  font-size: 16px;
  font-weight: 600;
  color: white;
  margin-top: 16px;
  transition: all 0.2s;
  width: 100%;
  border: none;
}

.submit-btn.active {
  background: #ff7a1c;
}

.submit-btn[disabled] {
  opacity: 0.6;
}