<!--pages/Register_Vendor/Register_Vendor.wxml-->
<view class="container">
  <view class="form-card">
    <view class="form-title">申请成为摊主</view>
    <view class="form-desc">填写信息后，我们会尽快审核</view>

    <!-- 店铺名称 -->
    <view class="form-item">
      <text class="form-label">店铺名称 <text class="required">*</text></text>
      <input class="form-input" placeholder="例：周姐炸串" bindinput="onShopNameInput" value="{{shopName}}"/>
    </view>

    <!-- 店铺类别 -->
    <view class="form-item">
      <text class="form-label">店铺类别 <text class="required">*</text></text>
      <picker bindchange="onCategoryChange" range="{{categoryOptions}}">
        <view class="picker-view">
          {{category || '请选择店铺类别'}}
          <text class="remixicon ri-arrow-down-s-line"></text>
        </view>
      </picker>
    </view>

    <!-- 营业时间 -->
    <view class="form-item">
      <text class="form-label">营业时间 <text class="required">*</text></text>
      <picker mode="multiSelector" bindchange="onHoursChange" range="{{hoursRange}}" value="{{hoursIndex}}">
        <view class="picker-view">
          {{businessHoursDisplay || '请选择营业时间'}}
          <text class="remixicon ri-arrow-down-s-line"></text>
        </view>
      </picker>
    </view>

    <!-- 店铺位置 -->
    <view class="form-item">
      <text class="form-label">摊位位置描述 <text class="required">*</text></text>
      <input class="form-input" placeholder="例：南门美食街中段第8号摊位" bindinput="onLocationInput" value="{{location}}"/>
    </view>

    <!-- 店铺简介 -->
    <view class="form-item">
      <text class="form-label">店铺简介</text>
      <textarea class="form-textarea" placeholder="介绍一下您的特色菜品..." bindinput="onDescriptionInput" value="{{description}}" maxlength="200"/>
      <view class="char-count">{{description.length}}/200</view>
    </view>

    <!-- 微信群二维码 -->
    <view class="form-item">
      <text class="form-label">微信群二维码</text>
      <view class="upload-area" bindtap="uploadQRCode">
        <text class="upload-icon">📱</text>
        <text>{{qrCodeUrl ? '已上传' : '点击上传微信群二维码'}}</text>
      </view>
      <view class="upload-hint">学生扫码进群后可第一时间获取优惠信息</view>
      <image wx:if="{{qrCodeUrl}}" class="preview-image" src="{{qrCodeUrl}}" mode="aspectFill" bindtap="previewImage" data-url="{{qrCodeUrl}}"></image>
    </view>

    <!-- 营业执照/健康证 -->
    <view class="form-item">
      <text class="form-label">健康证/备案证明</text>
      <view class="upload-area" bindtap="uploadLicense">
        <text class="upload-icon">➕</text>
        <text>上传证件照片</text>
      </view>
      <view class="upload-hint">支持jpg、png格式，最多3张</view>
      
      <!-- 已上传图片列表 -->
      <view class="image-list" wx:if="{{licenseImages.length > 0}}">
        <view class="image-item" wx:for="{{licenseImages}}" wx:key="index">
          <image src="{{item}}" mode="aspectFill" bindtap="previewLicense" data-url="{{item}}"></image>
          <view class="delete-btn" bindtap="deleteLicense" data-index="{{index}}">✕</view>
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <button class="submit-btn {{canSubmit && !submitting ? 'active' : ''}}" bindtap="submitRegister" disabled="{{!canSubmit || submitting}}">
      {{submitting ? '提交中...' : '提交申请'}}
    </button>
  </view>
</view>