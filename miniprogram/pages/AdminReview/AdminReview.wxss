/* pages/AdminReview/AdminReview.wxss */
.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 20px;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #ff7a1c, #ff9f4a);
  margin: 16px;
  padding: 20px;
  border-radius: 24px;
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 28px;
  font-weight: 700;
  color: white;
  display: block;
}

.stat-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4px;
}

/* 标签页 */
.tab-bar {
  background: white;
  display: flex;
  margin: 0 16px;
  border-radius: 40px;
  padding: 4px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 14px;
  border-radius: 40px;
  color: #666;
}

.tab-item.active {
  background: #ff7a1c;
  color: white;
  font-weight: 500;
}

/* 申请列表 */
.application-list {
  padding: 16px;
}

.application-card {
  background: white;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 16px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 10px;
  border-bottom: 0.5px solid #f0f0f0;
}

.shop-name {
  font-size: 18px;
  font-weight: 700;
}

.shop-category {
  font-size: 12px;
  color: #ff7a1c;
  background: #fff1e6;
  padding: 2px 8px;
  border-radius: 20px;
  margin-left: 8px;
}

.status-badge {
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 20px;
}

.status-badge.pending {
  background: #fff3e0;
  color: #ff9800;
}

.status-badge.approved {
  background: #e8f5e9;
  color: #4caf50;
}

.status-badge.rejected {
  background: #ffebee;
  color: #f44336;
}

.card-info {
  margin-bottom: 12px;
}

.info-row {
  display: flex;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.info-row text:first-child {
  width: 100px;
  color: #999;
}

.info-row text:last-child {
  flex: 1;
  color: #333;
}

/* 证件图片 */
.license-section, .qrcode-section {
  margin-top: 12px;
  padding-top: 10px;
  border-top: 0.5px solid #f0f0f0;
}

.section-label {
  font-size: 13px;
  color: #666;
  display: block;
  margin-bottom: 8px;
}

.license-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.license-images image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  background: #f5f5f5;
}

.qrcode-img {
  width: 120px;
  height: 120px;
  border-radius: 12px;
  background: #f5f5f5;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 12px;
  margin-top: 16px;
  padding-top: 12px;
  border-top: 0.5px solid #f0f0f0;
}

.btn {
  flex: 1;
  text-align: center;
  padding: 10px;
  border-radius: 40px;
  font-size: 14px;
  font-weight: 500;
}

.btn.reject {
  background: #f5f5f5;
  color: #f44336;
}

.btn.approve {
  background: #ff7a1c;
  color: white;
}

.review-comment {
  margin-top: 12px;
  padding: 10px;
  background: #f5f5f5;
  border-radius: 12px;
  font-size: 12px;
  color: #666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

.loading-state {
  text-align: center;
  padding: 40px;
  color: #999;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  width: 80%;
  background: white;
  border-radius: 24px;
  overflow: hidden;
}

.modal-title {
  text-align: center;
  font-size: 18px;
  font-weight: 600;
  padding: 20px;
  border-bottom: 0.5px solid #f0f0f0;
}

.modal-content {
  padding: 20px;
}

.reject-input {
  width: 100%;
  background: #f5f5f5;
  border-radius: 12px;
  padding: 12px;
  font-size: 14px;
  min-height: 100px;
}

.char-count {
  text-align: right;
  font-size: 11px;
  color: #bbb;
  margin-top: 6px;
}

.modal-buttons {
  display: flex;
  border-top: 0.5px solid #f0f0f0;
}

.modal-cancel, .modal-confirm {
  flex: 1;
  text-align: center;
  padding: 16px;
  font-size: 16px;
}

.modal-cancel {
  color: #999;
  border-right: 0.5px solid #f0f0f0;
}

.modal-confirm {
  color: #ff7a1c;
  font-weight: 600;
}