<!--pages/WriteReview/WriteReview.wxml-->
<view class="container">
  <!-- 选择店铺 -->
  <!-- <view class="form-item">
    <text class="form-label">店铺 <text class="required">*</text></text>
    <picker bindchange="onShopChange" range="{{shopList}}" range-key="shopName" value="{{shopIndex}}">
      <view class="picker-view">
        {{selectedShop ? selectedShop.shopName : '请选择店铺'}}
        <text>▼</text>
      </view>
    </picker>
  </view> -->

  <!-- 选择店铺（支持多选） -->
  <view class="form-item">
    <text class="form-label">关联店铺 <text class="required">*</text></text>
    <text class="form-hint">可选择多个店铺</text>
    
    <!-- 已选店铺列表 -->
    <view class="selected-shops" wx:if="{{selectedShops.length > 0}}">
      <view class="selected-shop" wx:for="{{selectedShops}}" wx:key="id">
        <text>{{item.shopName}}</text>
        <text class="remove" bindtap="removeShop" data-index="{{index}}">✕</text>
      </view>
    </view>
    
    <!-- 添加店铺按钮 -->
    <view class="add-shop-btn" bindtap="showShopPicker">
      <text>+ 添加店铺</text>
    </view>
  </view>

  <!-- 话题标签 -->
  <view class="form-item">
    <text class="form-label">话题标签</text>
    <view class="tags-input-area">
      <view class="tag-item" wx:for="{{tags}}" wx:key="index">
        <text>#{{item}}</text>
        <text class="remove-tag" bindtap="removeTag" data-index="{{index}}">✕</text>
      </view>
      <input class="tag-input" placeholder="输入标签后按回车" bindconfirm="addTag" value="{{tagInput}}" bindinput="onTagInput"/>
    </view>
    <text class="form-hint">例：夜宵、宝藏小店、实惠、排队王</text>
  </view>

  <!-- 评分 -->
  <view class="form-item">
    <text class="form-label">评分 <text class="required">*</text></text>
    <view class="rating-input">
      <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" 
        class="star {{rating >= item ? 'active' : ''}}" 
        bindtap="setRating" data-rating="{{item}}">⭐</text>
    </view>
  </view>

  <!-- 内容 -->
  <view class="form-item">
    <text class="form-label">评价内容 <text class="required">*</text></text>
    <textarea class="form-textarea" placeholder="分享你的美食体验..." bindinput="onContentInput" value="{{content}}" maxlength="500"/>
    <view class="char-count">{{content.length}}/500</view>
  </view>

  <!-- 图片上传 -->
  <view class="form-item">
    <text class="form-label">晒图</text>
    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image src="{{item}}" mode="aspectFill"></image>
        <view class="delete-img" bindtap="deleteImage" data-index="{{index}}">✕</view>
      </view>
      <view class="add-image" wx:if="{{images.length < 9}}" bindtap="chooseImage">
        <text>+</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <button class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="submitReview" disabled="{{!canSubmit}}">
    发布评价
  </button>
</view>