/* pages/WriteReview/WriteReview.wxss */
.container {
  padding: 16px;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.form-item {
  background: white;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 12px;
}

.form-label {
  font-size: 15px;
  font-weight: 500;
  display: block;
  margin-bottom: 12px;
}

.required {
  color: #ff4d4f;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  color: #333;
}

/* 已选店铺样式 */
.selected-shops {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 12px;
}

.selected-shop {
  background: #ff7a1c;
  color: white;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.selected-shop .remove {
  font-size: 14px;
  font-weight: bold;
}

.add-shop-btn {
  background: #f5f5f5;
  padding: 10px;
  text-align: center;
  border-radius: 12px;
  color: #ff7a1c;
  font-size: 14px;
}

/* 标签区域 */
.tags-input-area {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12px;
  padding: 10px;
}

.tag-item {
  background: #ff7a1c;
  color: white;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.remove-tag {
  font-size: 12px;
  font-weight: bold;
}

.tag-input {
  flex: 1;
  min-width: 100px;
  background: transparent;
  padding: 6px 0;
  font-size: 13px;
}

.form-hint {
  font-size: 11px;
  color: #999;
  margin-top: 6px;
  display: block;
}

.rating-input {
  display: flex;
  gap: 8px;
}

.star {
  font-size: 32px;
  opacity: 0.3;
}

.star.active {
  opacity: 1;
}

.form-textarea {
  width: 100%;
  box-sizing: border-box; 
  background: #f5f5f5;
  border-radius: 12px;
  padding: 12px;
  font-size: 14px;
  min-height: 150px;
}

.char-count {
  text-align: right;
  font-size: 11px;
  color: #bbb;
  margin-top: 6px;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.image-item {
  position: relative;
  width: 100px;
  height: 100px;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 12px;
}

.delete-img {
  position: absolute;
  top: -8px;
  right: -8px;
  width: 24px;
  height: 24px;
  background: #ff4d4f;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.add-image {
  width: 100px;
  height: 100px;
  background: #f5f5f5;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  color: #ccc;
}

.submit-btn {
  background: #e0e0e0;
  border-radius: 40px;
  padding: 14px;
  font-size: 16px;
  font-weight: 600;
  color: white;
  margin-top: 20px;
}

.submit-btn.active {
  background: #ff7a1c;
}