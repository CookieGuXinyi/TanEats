/* pages/Register_User/Register_User.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff7a1c 0%, #ff9f4a 100%);
  padding: 40px 20px 30px;
}

/* 顶部装饰 */
.top-decoration {
  text-align: center;
  margin-bottom: 40px;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 8px;
}

.logo text:first-child {
  font-size: 48px;
}

.logo-text {
  font-size: 32px;
  font-weight: 700;
  color: white;
}

.slogan {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单卡片 */
.form-card {
  background: white;
  border-radius: 32px;
  padding: 28px 24px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
}

/* 切换选项卡 */
.tab-switch {
  display: flex;
  margin-bottom: 30px;
  background: #f5f5f5;
  border-radius: 40px;
  padding: 4px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 16px;
  font-weight: 500;
  color: #999;
  border-radius: 40px;
  transition: all 0.2s;
}

.tab-item.active {
  background: #ff7a1c;
  color: white;
  box-shadow: 0 2px 8px rgba(255, 122, 28, 0.3);
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 16px;
  padding: 4px 16px;
  margin-bottom: 16px;
}

.input-icon {
  font-size: 20px;
  margin-right: 12px;
}

.form-input {
  flex: 1;
  padding: 14px 0;
  font-size: 15px;
  background: transparent;
}

.code-item {
  padding-right: 8px;
}

.code-input {
  flex: 1;
}

.get-code {
  background: #f0f0f0;
  padding: 8px 12px;
  border-radius: 30px;
  font-size: 12px;
  color: #999;
  white-space: nowrap;
}

.get-code.active {
  background: #ff7a1c;
  color: white;
}

/* 复选框 */
.remember-me, .agree-terms {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #666;
}

.checkbox {
  width: 18px;
  height: 18px;
  border: 1.5px solid #ddd;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: white;
}

.checkbox.checked {
  background: #ff7a1c;
  border-color: #ff7a1c;
}

.forgot-pwd {
  font-size: 13px;
  color: #ff7a1c;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

/* 按钮 */
.login-btn, .register-btn {
  background: #e0e0e0;
  border-radius: 40px;
  text-align: center;
  padding: 14px;
  font-size: 16px;
  font-weight: 600;
  color: white;
  margin-top: 8px;
  transition: all 0.2s;
}

.login-btn.active, .register-btn.active {
  background: #ff7a1c;
}

.wx-login-btn {
  background: #07c160;
  border-radius: 40px;
  text-align: center;
  padding: 14px;
  font-size: 16px;
  font-weight: 500;
  color: white;
  margin-top: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

/* 其他注册方式 */
.other-register {
  margin-top: 28px;
}

.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  margin-bottom: 20px;
}

.divider .line {
  flex: 1;
  height: 0.5px;
  background: #e0e0e0;
}

.divider text {
  font-size: 12px;
  color: #999;
}

.social-icons {
  display: flex;
  justify-content: center;
  gap: 40px;
}

.social-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: #666;
}

.social-icon text:first-child {
  font-size: 32px;
}

.link {
  color: #ff7a1c;
}

.footer-note {
  text-align: center;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 20px;
}