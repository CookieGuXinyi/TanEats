<!--pages/ReviewDetail/ReviewDetail.wxml-->
<view class="container" wx:if="{{review && !notFound}}">
  
  <!-- 用户信息 -->
  <view class="user-info">
    <view class="avatar">
      <text>👤</text>
    </view>
    <view class="user-detail">
      <text class="user-name">{{review.reviewerName}}</text>
      <text class="review-time">{{review.createTimeFormatted}}</text>
    </view>
  </view>

  <!-- 关联店铺（多店时显示标签区域） -->
  <view class="shop-tags-section" wx:if="{{review.shopNames && review.shopNames.length > 0}}">
    <view class="section-header">
      <text class="shop-tags-title">📌 关联店铺（点击进入）</text>
      <view class="rating">
        <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
          {{review.rating >= item ? '⭐' : ''}}
        </text>
      </view>
    </view>
    <view class="shop-tags">
      <text class="shop-tag" wx:for="{{review.shopNames}}" wx:key="index" data-index="{{index}}" bindtap="goToShop">📍 {{item}}</text>
    </view>
  </view>

  <!-- 店铺和评分 -->
  <!-- <view class="shop-info" wx:else>
    <text class="shop-name">📍 {{review.shopNames[0]}}</text>
    <view class="rating">
      <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
        {{review.rating >= item ? '⭐' : '☆'}}
      </text>
    </view>
  </view> -->

  <!-- 话题标签 -->
  <view class="topic-tags-section" wx:if="{{review.tags && review.tags.length > 0}}">
    <view class="topic-tags-title">🏷️ 话题标签</view>
    <view class="topic-tags">
      <text class="topic-tag" wx:for="{{review.tags}}" wx:key="index">#{{item}}</text>
    </view>
  </view>

  <!-- 内容 -->
  <view class="content">
    <text>{{review.content}}</text>
  </view>

  <!-- 图片列表 -->
  <view class="image-list" wx:if="{{review.images && review.images.length > 0}}">
    <image wx:for="{{review.images}}" wx:key="index" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}"></image>
  </view>

  <!-- 互动栏 -->
  <view class="action-bar">
    <view class="action-item" bindtap="toggleLike">
      <text>{{review.isLiked ? '❤️' : '🤍'}}</text>
      <text>{{review.likeCount || 0}}</text>
    </view>
  </view>

</view>

<!-- 未找到提示 -->
<view class="not-found" wx:else>
  <text class="not-found-icon">🔍</text>
  <text class="not-found-text">找不到当前评论</text>
  <text class="not-found-desc">该评论可能已被删除或不存在</text>
</view>