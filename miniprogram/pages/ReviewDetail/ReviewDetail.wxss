/* pages/ReviewDetail/ReviewDetail.wxss */
.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding: 16px;
}

.user-info {
  background: white;
  border-radius: 20px;
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.avatar {
  width: 50px;
  height: 50px;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.user-name {
  font-size: 16px;
  font-weight: 600;
  display: block;
}

.review-time {
  font-size: 11px;
  color: #999;
}

.shop-info {
  background: white;
  border-radius: 20px;
  padding: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.shop-name {
  font-size: 14px;
  color: #ff7a1c;
}

.rating {
  display: flex;
  gap: 2px;
}

.star {
  font-size: 16px;
  opacity: 0.3;
}

.star.active {
  opacity: 1;
}

/* 新增：关联店铺标签区域（如果有多个店铺） */
.shop-tags-section {
  background: white;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.shop-tags-title {
  font-size: 14px;
  color: #333;
  line-height: 1;
}

.section-header .rating {
  display: flex;
  gap: 2px;
  align-items: center;
  line-height: 1; 
}

.shop-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.shop-tag {
  background: #fff1e6;
  color: #ff7a1c;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
}

/* 话题标签区域 */
.topic-tags-section {
  background: white;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 12px;
}

.topic-tags-title {
  font-size: 13px;
  color: #999;
  margin-bottom: 8px;
}

.topic-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.topic-tag {
  background: #e8f5e9;
  color: #4caf50;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
}

.content {
  background: white;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 12px;
  font-size: 15px;
  line-height: 1.5;
}

.image-list {
  background: white;
  border-radius: 20px;
  padding: 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 12px;
}

.image-list image {
  width: calc(33.33% - 6px);
  height: 120px;
  border-radius: 12px;
}

.action-bar {
  background: white;
  border-radius: 20px;
  padding: 12px 16px;
  display: flex;
  gap: 24px;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  color: #666;
}

.loading {
  text-align: center;
  padding: 60px;
  color: #999;
}

/* 未找到提示样式 */
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f8f8f8;
}

.not-found-icon {
  font-size: 64px;
  margin-bottom: 20px;
}

.not-found-text {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.not-found-desc {
  font-size: 14px;
  color: #999;
  margin-bottom: 30px;
}