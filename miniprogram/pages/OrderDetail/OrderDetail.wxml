<!--pages/OrderDetail/OrderDetail.wxml-->
<view class="container" wx:if="{{order}}">
  
  <!-- 状态卡片 -->
  <view class="status-card">
    <view class="status-icon">
      {{order.status === 'pending' ? '⏳' : (order.status === 'completed' ? '✅' : '📦')}}
    </view>
    <text class="status-text">{{order.statusText}}</text>
    <text class="status-desc">{{order.statusDesc}}</text>
  </view>
  
  <!-- 订单信息 -->
  <view class="info-card">
    <view class="info-row">
      <text>订单号</text>
      <text>{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text>下单时间</text>
      <text>{{order.createTimeFormatted}}</text>
    </view>
    <view class="info-row">
      <text>取餐时间</text>
      <text>{{order.pickupTime || '未选择'}}</text>
    </view>
  </view>
  
  <!-- 店铺信息 -->
  <view class="info-card">
    <view class="info-title">店铺信息</view>
    <view class="info-row">
      <text>店铺名称</text>
      <text>{{order.stallName}}</text>
    </view>
  </view>
  
  <!-- 商品列表 -->
  <view class="info-card">
    <view class="info-title">商品清单</view>
    <view class="product-item" wx:for="{{order.items}}" wx:key="productId">
      <text>{{item.productName}} x{{item.quantity}}</text>
      <text>¥{{item.price * item.quantity}}</text>
    </view>
    <view class="total-row">
      <text>共{{order.totalQuantity}}件 合计</text>
      <text class="total-price">¥{{order.totalAmount}}</text>
    </view>
  </view>
  
  <!-- 备注 -->
  <view class="info-card" wx:if="{{order.remark}}">
    <view class="info-title">备注</view>
    <text>{{order.remark}}</text>
  </view>
  
</view>

<view class="loading" wx:else>
  <text>加载中...</text>
</view>