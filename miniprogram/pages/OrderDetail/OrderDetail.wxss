/* pages/OrderDetail/OrderDetail.wxss */
.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding: 16px;
}

.status-card {
  background: white;
  border-radius: 20px;
  padding: 24px;
  text-align: center;
  margin-bottom: 12px;
}

.status-icon {
  font-size: 48px;
  display: block;
  line-height: 1;
  margin-bottom: 8px;
}

.status-text {
  font-size: 18px;
  font-weight: 600;
  display: block;
  margin-bottom: 6px;
}

.status-desc {
  font-size: 13px;
  color: #999;
}

.info-card {
  background: white;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 12px;
}

.info-title {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 0.5px solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  font-size: 14px;
}

.product-item {
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 0.5px solid #f5f5f5;
  font-size: 14px;
}

.total-row {
  display: flex;
  justify-content: space-between;
  padding-top: 12px;
  margin-top: 8px;
  border-top: 0.5px solid #f0f0f0;
  font-size: 14px;
  font-weight: 500;
}

.total-price {
  font-size: 16px;
  font-weight: 600;
  color: #ff7a1c;
}

.loading {
  text-align: center;
  padding: 60px;
  color: #999;
}