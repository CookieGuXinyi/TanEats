<!--pages/Profile/Profile.wxml-->

<!-- 未登录状态 -->
<view class="container" wx:if="{{!isLogin}}">
  <view class="login-prompt">
    <view class="login-icon">👤</view>
    <view class="login-title">登录TanEats</view>
    <view class="login-desc">发现更多美食 · 参与拼单优惠</view>
    <view class="login-btn" bindtap="goToLogin">立即登录 / 注册</view>
    <view class="wx-login-btn" bindtap="handleWxLogin">
      <text>💚</text>
      微信一键登录
    </view>
  </view>

  <!-- 未登录时展示部分功能预览 -->
  <view class="preview-card">
    <view class="preview-title">登录后解锁更多功能</view>
    <view class="preview-list">
      <view class="preview-item">
        <text>🎫</text>
        <text>领取专属优惠券</text>
      </view>
      <view class="preview-item">
        <text>👥</text>
        <text>参与跨摊拼单</text>
      </view>
      <view class="preview-item">
        <text>⭐</text>
        <text>收藏喜欢的摊位</text>
      </view>
      <view class="preview-item">
        <text>🏪</text>
        <text>申请成为摊主</text>
      </view>
    </view>
  </view>
</view>

<!-- 已登录状态 -->
<view class="container" wx:else>
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar">
      <text style="font-size: 40px;">{{userInfo.avatar || '👤'}}</text>
    </view>
    <view class="user-info">
      <view class="user-name">{{userInfo.nickname !== undefined ?  userInfo.nickname : '校园食客'}}</view>
      <view class="user-phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</view>
      <view class="user-stats">
        <text>积分: {{userInfo.points !== undefined ? userInfo.points : 0}}</text>
        <text>优惠券: {{userInfo.coupons !== undefined ? userInfo.coupons : 0}}张</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goToVendor">
      <view class="menu-left">
        <text>🏪</text>
        <text>摊主工作台</text>
      </view>
      <text>></text>
    </view>
    <view class="menu-item" bindtap="goToVendorRegister">
      <view class="menu-left">
        <text>➕</text>
        <text>申请成为摊主</text>
      </view>
      <text>></text>
    </view>
    <view class="menu-item" bindtap="goToMyApplications">
      <view class="menu-left">
        <text>📋</text>
        <text>我的申请记录</text>
      </view>
      <text>></text>
    </view>
    <view class="menu-item" bindtap="goToCollection">
      <view class="menu-left">
        <text>❤️</text>
        <text>我的收藏</text>
      </view>
      <text>></text>
    </view>
    <view class="menu-item" bindtap="goToAdmin">
      <view class="menu-left">
        <text>🕐</text>
        <text>店铺审核</text>
      </view>
      <text>></text>
    </view>
  </view>

  <!-- 订单相关 -->
  <view class="menu-card">
    <view class="card-title">我的订单</view>
    <view class="order-icons">
      <view class="order-icon" bindtap="goToOrder" data-status="pending">
        <text>💰</text>
        <text>待付款</text>
      </view>
      <view class="order-icon" bindtap="goToOrder" data-status="ongoing">
        <text>🚚</text>
        <text>进行中</text>
      </view>
      <view class="order-icon" bindtap="goToOrder" data-status="completed">
        <text>✅</text>
        <text>已完成</text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goToResetPW">
      <view class="menu-left">
        <text>🔐</text>
        <text>密码重置</text>
      </view>
      <text>></text>
    </view>
    <view class="menu-item" bindtap="goToSetting">
      <view class="menu-left">
        <text>🔔</text>
        <text>通知偏好</text>
      </view>
      <text>></text>
    </view>
    <view class="menu-item" bindtap="goToAboutUs">
      <view class="menu-left">
        <text>❓</text>
        <text>关于TanEats</text>
      </view>
      <text>></text>
    </view>
    <!-- 退出登录按钮 -->
    <view class="menu-item logout-item" bindtap="logout">
      <view class="menu-left">
        <text>🚪</text>
        <text class="logout-text">退出登录</text>
      </view>
      <text>></text>
    </view>
  </view>
</view>