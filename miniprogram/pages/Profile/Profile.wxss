/* pages/Profile/Profile.wxss */
.container {
  padding: 12px 16px;
}

/* ========== 未登录状态样式 ========== */
.login-prompt {
  background: linear-gradient(135deg, #ff7a1c, #ff9f4a);
  border-radius: 32px;
  padding: 40px 24px;
  text-align: center;
  margin-bottom: 20px;
}

.login-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.login-title {
  font-size: 24px;
  font-weight: 700;
  color: white;
  margin-bottom: 8px;
}

.login-desc {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 28px;
}

.login-prompt .login-btn {
  background: white;
  border-radius: 40px;
  text-align: center;
  padding: 14px;
  font-size: 16px;
  font-weight: 600;
  color: #ff7a1c;
  margin-bottom: 12px;
}

.wx-login-btn {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40px;
  text-align: center;
  padding: 12px;
  font-size: 15px;
  font-weight: 500;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 0.5px solid rgba(255, 255, 255, 0.3);
}

.preview-card {
  background: white;
  border-radius: 24px;
  padding: 20px;
}

.preview-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16px;
  text-align: center;
}

.preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.preview-item {
  flex: 1;
  min-width: calc(50% - 8px);
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 0;
  font-size: 14px;
  color: #666;
  border-bottom: 0.5px solid #f5f5f5;
}

.preview-item text:first-child {
  font-size: 20px;
}

/* ========== 已登录状态样式 ========== */
.user-card {
  background: linear-gradient(135deg, #ff7a1c, #ff9f4a);
  border-radius: 24px;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
}

.avatar {
  background: rgba(255,255,255,0.3);
  width: 60px;
  height: 60px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-info {
  color: white;
}

.user-name {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 6px;
}

.user-stats {
  display: flex;
  gap: 16px;
  font-size: 12px;
  opacity: 0.9;
}

.menu-card {
  background: white;
  border-radius: 20px;
  padding: 8px 16px;
  margin-bottom: 12px;
}

.card-title {
  font-weight: 600;
  font-size: 14px;
  padding: 12px 0;
  color: #666;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 0.5px solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 15px;
}

.logout-item {
  border-bottom: 0.5px solid #f0f0f0;
  margin-bottom: 8px;
}

.logout-text {
  color: #ff4d4f;
}

.order-icons {
  display: flex;
  justify-content: space-around;
  padding: 12px 0 20px;
}

.order-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: #666;
}

.order-icon text:first-child {
  font-size: 24px;
}