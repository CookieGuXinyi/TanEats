<!--pages/Orders/Orders.wxml-->
<view class="container">
  
  <!-- 标签页 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab-item {{currentTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">进行中</view>
    <view class="tab-item {{currentTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">已完成</view>
  </view>
  
  <!-- 订单列表 -->
  <view class="order-list">
    <block wx:for="{{orders}}" wx:key="_id">
      <view class="order-card" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="order-header">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-status {{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="order-shop">{{item.stallName}}</view>
        <view class="order-items">
          <text wx:for="{{item.items}}" wx:key="productId" wx:for-item="i">
            {{i.productName}} x{{i.quantity}}
          </text>
        </view>
        <view class="order-footer">
          <text>共{{item.totalQuantity}}件 合计</text>
          <text class="order-price">¥{{item.totalAmount}}</text>
        </view>
      </view>
    </block>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{orders.length === 0 && !loading}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无订单</text>
    <view class="go-shop-btn" bindtap="goToDiscover">去逛逛</view>
  </view>
  
</view>